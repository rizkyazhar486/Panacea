# Panaceamed.id backend configuration.
# Copy to ".env" and fill in. Any value left blank keeps that feature in MOCK mode.

# --- Server ---
PORT=8787
# Comma-separated allowed origins for CORS (your frontend URLs)
CORS_ORIGINS=http://localhost:5173,https://rizkyazhar486.github.io
# Secret used to sign session JWTs (set to a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string
# Set to "true" when serving over HTTPS so the session cookie is Secure
COOKIE_SECURE=false

# --- Google OAuth (real login) ---
# Create at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, type "Web")
# Leave blank to use dev-login (mock) instead.
GOOGLE_CLIENT_ID=

# --- Midtrans payments (real QRIS / Virtual Account / Card) ---
# Get sandbox keys at https://dashboard.sandbox.midtrans.com/settings/config_info
# Leave MIDTRANS_SERVER_KEY blank to use mock payments.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# 1 PanaceaToken (PNC) in IDR
TOKEN_TO_IDR=1000
