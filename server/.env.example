# Panaceamed.id backend configuration.
# Copy to ".env" and fill in. Any value left blank keeps that feature in MOCK mode.

# --- AI (OpenRouter — one key, many models) ---
# Get a key at https://openrouter.ai/keys. With OPENROUTER_API_KEY set, ALL AI
# runs through OpenRouter and you don't need ANTHROPIC_API_KEY at all:
#   • Patient Chatbot  → AI_CHAT_MODEL (default: google/gemini-3.5-flash)
#   • AI-EMR / Edukasi → AI_EMR_MODEL  (default: z-ai/glm-5.2)
# The two AI_* lines are OPTIONAL — defaults already match the intended setup,
# so the only REQUIRED variable here is OPENROUTER_API_KEY.
OPENROUTER_API_KEY=
AI_CHAT_MODEL=google/gemini-3.5-flash
AI_EMR_MODEL=z-ai/glm-5.2
# Alternative: use Anthropic directly instead of OpenRouter (leave OPENROUTER_API_KEY blank).
ANTHROPIC_API_KEY=

# --- Server ---
PORT=8787
# Comma-separated allowed origins for CORS (your frontend URLs)
CORS_ORIGINS=http://localhost:5173,https://rizkyazhar486.github.io
# Secret used to sign session JWTs (set to a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string
# Set to "true" when serving over HTTPS so the session cookie is Secure
COOKIE_SECURE=false

# --- Google OAuth (real login) ---
# Create at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, type "Web")
# Leave blank to use dev-login (mock) instead.
GOOGLE_CLIENT_ID=

# --- Midtrans payments (real QRIS / Virtual Account / Card) ---
# Get sandbox keys at https://dashboard.sandbox.midtrans.com/settings/config_info
# Leave MIDTRANS_SERVER_KEY blank to use mock payments.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# 1 PanaceaToken (PNC) in IDR
TOKEN_TO_IDR=1000

# --- Web Push notifications (owner alerts, withdrawal/verification pings) ---
# Unlike JWT_SECRET, these CANNOT be "any random string" — they must be a real
# VAPID (Voluntary Application Server Identification) EC keypair, or every
# browser subscribe attempt silently fails and push stays disabled for everyone,
# including the owner. Generate a real pair with:
#   npx web-push generate-vapid-keys
# Paste the two output values below (see PANDUAN-SETUP.md, Bagian 7, for the
# Render walkthrough). Leave both blank to keep push in mock/off mode.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@panaceamed.id
