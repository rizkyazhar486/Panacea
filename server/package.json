    "google-auth-library": "^9.14.1",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.2",
    "mongodb": "^6.9.0",
    "tsx": "^4.19.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.5",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.2"
