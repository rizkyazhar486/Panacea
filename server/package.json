{
  "name": "panaceamed-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Panaceamed.id backend — Google OAuth login + Midtrans payments (real, with mock fallback)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
